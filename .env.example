# ─────────────────────────────────────────────────────────────
#  PLANTILLA DE VARIABLES — copia este archivo como ".env" y rellena
#  los valores reales. El archivo .env NO se sube a GitHub (.gitignore).
#
#  En GitHub estos mismos valores se guardan como "Secrets" del repo
#  (Settings → Secrets and variables → Actions), NO en el código.
# ─────────────────────────────────────────────────────────────

# --- Supabase (base de datos) ---
# Las encuentras en: Supabase → Project Settings → API
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# La "service_role" la usan SOLO los scripts del servidor (GitHub Actions). Es secreta.
SUPABASE_SERVICE_KEY=pega_aqui_tu_service_role_key
# La "anon" la usa la web (es pública, va en web/config.js)
SUPABASE_ANON_KEY=pega_aqui_tu_anon_key

# --- Telegram ---
# El token te lo da @BotFather al crear el bot.
# OJO: ya NO hay un chat_id único. Cada persona vincula su Telegram
# desde la propia app (se guarda en su perfil dentro de la base de datos).
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Configuración ---
# Tu zona horaria IANA. Ejemplos: America/Lima, America/Bogota, America/Guayaquil
TIMEZONE=America/Lima
# Cuántos días "próximos" mostrar en el resumen de la mañana
NEXT_DAYS=3
